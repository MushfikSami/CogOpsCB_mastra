# --- Concurrency Control ---
SEMAPHORE_LIMIT=10

# --- Neo4j Database ---
NEO4J_URI="bolt://localhost:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="your_password_here"

# --- LLM Provider ---
VLLM_BASE_URL="http://localhost:5000/v1/"
VLLM_API_KEY="your_api_key_here"
VLLM_MODEL_NAME="your_model_name_here"

# --- Embedder (Triton) ---
TRITON_URL="localhost:6000"
TRITON_MODEL_NAME="gemma_embedding"
TRITON_TOKENIZER="onnx-community/embeddinggemma-300m-ONNX"