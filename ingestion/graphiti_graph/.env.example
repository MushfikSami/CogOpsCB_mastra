# --- Concurrency Control ---
# Controls Graphiti's internal parallelism to prevent 429 errors
SEMAPHORE_LIMIT=1

# --- Neo4j Database ---
# Use bolt+ssc:// if using self-signed certificates, otherwise bolt://
NEO4J_URI="bolt+ssc://localhost:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# --- LLM (vLLM / Qwen) ---
VLLM_BASE_URL="http://localhost:5000/v1/"
VLLM_API_KEY="XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
VLLM_MODEL_NAME="cyankiwi/Qwen3-30B-A3B-Instruct-2507-AWQ-4bit"

# --- Embedder (Triton) ---
TRITON_URL="localhost:6000"
TRITON_MODEL_NAME="gemma_embedding"
TRITON_TOKENIZER="onnx-community/embeddinggemma-300m-ONNX"