# --- Primary LLM (Agent Reasoning + Native Thinking) ---
LLM_BASE_URL="http://localhost:5000/v1/"
LLM_API_KEY="your-api-key-here"
LLM_MODEL_NAME="qwen36"

# --- Secondary LLM (intent classifier + NLI verifier; wired in steps 4–5) ---
SECONDARY_BASE_URL="http://localhost:5000/v1/"
SECONDARY_API_KEY="your-api-key-here"
SECONDARY_MODEL_NAME="qwen36"

# --- Jiggasha Knowledge Service (Bengali Qdrant + reranker retrieval) ---
JIGGASHA_ENDPOINT="http://172.22.11.241:10000/search"
JIGGASHA_TIMEOUT="8"
JIGGASHA_TOP_K="5"
JIGGASHA_MIN_SCORE="0.35"

# --- Wikipedia Search (reserved for future tool plugin) ---
WIKI_ENDPOINT="http://172.22.11.241:9220/search"

# --- Redis Session Store ---
REDIS_URL="redis://localhost:6379/0"
REDIS_SESSION_TTL_SECONDS="86400"

# --- Mastra Sidecar (Node/TypeScript agent + memory service) ---
# The FastAPI api.py proxies /chat/stream to this service.
MASTRA_URL="http://localhost:9100"
# Port the Mastra sidecar listens on (used by mastra/, mirrors MASTRA_URL).
MASTRA_PORT="9100"
# LibSQL/SQLite file backing threads + working/observational memory.
# Use a Turso URL (libsql://...) for hosted persistence.
MASTRA_DB_URL="file:./mastra.db"

# --- Debug ---
ADMIN_DEBUG_SECRET=""
