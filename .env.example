# --- Triton (Gemma Embedding) Connection ---
TRITON_URL="localhost:6000"
TRITON_MODEL_NAME="gemma_embedding"
TRITON_TOKENIZER="onnx-community/embeddinggemma-300m-ONNX"

# --- Primary LLM (Agent Reasoning + Native Thinking) ---
LLM_BASE_URL="http://localhost:5000/v1/"
LLM_API_KEY="XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
LLM_MODEL_NAME="qwen3-primary"

# --- Reranker LLM (Binary Classification) ---
RERANKER_BASE_URL="http://localhost:5001/v1/"
RERANKER_API_KEY="XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
RERANKER_MODEL_NAME="qwen3-reranker"

# --- Secondary LLM (General Tasks, Sub-agents) ---
SECONDARY_BASE_URL="http://localhost:5002/v1/"
SECONDARY_API_KEY="XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
SECONDARY_MODEL_NAME="qwen3-secondary"

# --- Neo4j Graphiti ---
NEO4J_URI="bolt+ssc://localhost:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# --- Debug ---
ADMIN_DEBUG_SECRET=""  # Set to a secret string to enable debug mode

# --- Tokenizer ---
TOKENIZER_MODEL_NAME="Qwen/Qwen2.5-32B-Instruct"

# --- Redis Session Store ---
REDIS_URL="redis://localhost:6379/0"
REDIS_SESSION_TTL_SECONDS="86400"

# --- Summarizer ---
SUMMARIZER_MAX_TOKENS="300"
# Optional dedicated summarizer endpoint (leave empty to reuse SECONDARY_*):
SUMMARIZER_BASE_URL=""
SUMMARIZER_API_KEY=""
SUMMARIZER_MODEL_NAME=""

CHROMA_DB_HOST="http://localhost"
CHROMA_DB_PORT="8443"